{
  "algo": "ppo_cnn",
  "batch_size": 16384,
  "checkpoint_freq": 20,
  "checkpoint_score_attr": "env_runners/episode_return_mean",
  "checkpoint_score_attr_eval": "evaluation/env_runners/episode_return_mean",
  "clip_range": 0.3,
  "debug": false,
  "entropy_coef": 0.01,
  "evaluation_explore": false,
  "evaluation_interval": 1,
  "evaluation_num_episodes": 30,
  "gamma": 0.995,
  "keep_checkpoints_num": 5,
  "lambda": 0.95,
  "learning_rate": 3.1628968744166736e-05,
  "minibatch_size": 1024,
  "num_envs": 31,
  "num_epochs": 10,
  "num_gpus": 1,
  "rollout_fragment_length": "auto",
  "seed": 42,
  "system_defaults": {
    "bigger_machine": {
      "debug": false,
      "max_concurrent_trials": 2,
      "num_envs": 8,
      "num_gpus": 1
    },
    "laptop_debug": {
      "debug": true,
      "max_concurrent_trials": 1,
      "num_envs": 3,
      "num_gpus": 0
    }
  },
  "total_timesteps": 30000000,
  "use_gae": true,
  "vf_coef": 0.5
}
