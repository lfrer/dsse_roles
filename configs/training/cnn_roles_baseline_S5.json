{
  "algo": "ppo_cnn_r3dm",
  "batch_size": 65536,
  "checkpoint_freq": 20,
  "checkpoint_score_attr": "env_runners/episode_return_mean",
  "checkpoint_score_attr_eval": "evaluation/env_runners/episode_return_mean",
  "clip_range": 0.3,
  "debug": false,
  "entropy_coef": 0.005,
  "evaluation_explore": false,
  "evaluation_interval": 1,
  "evaluation_num_episodes": 30,
  "gamma": 0.995,
  "keep_checkpoints_num": 5,
  "lambda": 0.95,
  "learning_rate": 1.5e-05,
  "minibatch_size": 4096,
  "num_envs": 31,
  "num_epochs": 5,
  "num_gpus": 1,
  "rollout_fragment_length": "auto",
  "seed": 42,
  "system_defaults": {
    "bigger_machine": {
      "debug": false,
      "max_concurrent_trials": 2,
      "num_envs": 8,
      "num_gpus": 1
    },
    "laptop_debug": {
      "debug": true,
      "max_concurrent_trials": 1,
      "num_envs": 3,
      "num_gpus": 0
    }
  },
  "total_timesteps": 30000000,
  "use_gae": true,
  "vf_coef": 1.0,
  "num_roles": 2,
  "role_emb_dim": 32,
  "role_temp": 1.0,
  "use_gumbel_roles": true,
  "gumbel_tau": 1.0,
  "gumbel_tau_start": 1.5,
  "gumbel_tau_end": 0.5,
  "gumbel_anneal_steps": 15000000,
  "gumbel_hard": false,
  "dyn_horizon": 8,
  "nce_temperature": 0.2,
  "aux_loss_coef": 0.02,
  "intrinsic_reward_coef": 0.0,
  "role_mi_coef": 0.03,
  "max_nce_pairs_loss": 1024,
  "max_nce_pairs_intrinsic": 512
}
